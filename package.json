{
  "name": "ree-pak-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run type-check && bun run build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:tauri": "bun tauri build --verbose",
    "release:package": "bun scripts/packageUpdateArtifact.js",
    "release:prepare": "bun run build:tauri && bun run release:package",
    "type-check": "vue-tsc --build --force",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "element-plus": "^2.13.2",
    "entities": "^7.0.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.28",

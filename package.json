{
  "name": "ree-pak-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run type-check && bun run build:model-insight-wasm && bun run build-only",
    "build:model-insight-wasm": "node scripts/buildModelInsightWasm.js",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:tauri": "bun tauri build --verbose",
    "release:package": "bun scripts/packageUpdateArtifact.js",
    "release:prepare": "bun run build:tauri && bun run release:package",
    "type-check": "vue-tsc --build --force",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "element-plus": "^2.13.7",
    "entities": "^7.0.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^22.19.17",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.8.1",
    "common-tags": "^1.8.2",
    "fflate": "^0.8.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.63.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.11",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.8"
  }
}

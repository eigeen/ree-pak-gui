    "@types/node": "^22.19.11",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.8.1",
    "common-tags": "^1.8.2",
    "fflate": "^0.8.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unplugin-element-plus": "^0.11.2",
